  #
  #  Delete Customer using BSFN.
  #
    /deleteCustomerUsingBSFN:
      delete:
        description: Delete Address Book using BSFN AddressBookMasterMBF.
        headers:
          mode:
            displayName: Mode
            description: Execution mode
            type: string
            required: true
