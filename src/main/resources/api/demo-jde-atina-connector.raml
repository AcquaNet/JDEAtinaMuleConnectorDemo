              application/json:
                example: !include examples/bsfn-prc-delete-customer.json
    /createSOUsingBSFN:
      post:
        description: Create SO using BSFN.
        headers:
          mode:
            displayName: Mode
            description: Execution mode
            type: string
            required: true
            enum: [JDE_PORTX, JDE_ATINA]
        body:
          application/json:
            type: object
            properties:
              deliverTo:
                displayName: Deliver To
                type: integer
                required: true
                example: 4242
              shipTo:
                displayName: Ship To
                type: integer
                required: true
                example: 4242
              dateRequested:
                displayName: Date Requested
                type: date-only
                required: true
                example: 2025-12-20
              detail:
                displayName: Detail Lines
                type: array
                required: true
                minItems: 1
                items:
                  type: object
                  properties:
                    quantityOrdered:
                      displayName: Quantity Ordered
                      type: integer
                      required: true
                      minimum: 1
                      example: 1
                    itemId:
                      displayName: Item ID
                      type: string
                      required: true
                      example: '210'
            example: |
              {
                "deliverTo": 4242,
                "shipTo": 4242,
                "dateRequested": "2025-12-20",
                "detail": [
                  { "quantityOrdered": 1, "itemId": "210" },
                  { "quantityOrdered": 2, "itemId": "220" }
                ]
              }
        responses:
          200:
            description: OK
            body:
              application/json:
                example: !include examples/bsfn-post-so.json            
#  ===========================================
#  SUBMIT UBE
#  ===========================================
#
#  Get Full Customer Information BSFN AddressBookMasterMBF.
#
#
#  Get Address Book using BSFN AddressBookMasterMBF.
#           
  /ube:
    /submitUBER01010Z:
      post:
        description: Sumbit UBE R01010Z-ZJDE0001 Address Book Batch Upload. 
        headers:
          mode:
            displayName: Mode
            description: Execution mode
            type: string
            required: true
            enum: [JDE_PORTX, JDE_ATINA]
        body:
          application/json:
            type: |
              {
                "type": "object",
                "properties": {
                  "PO_ProcessMode": {
                    "type": "string",
                    "pattern": "^[0,1]{1}$",
                    "displayName": "Process Mode",
                    "description": "Blank = Proof mode  or 1 = Final mode"
                  },
                  "DataSelection_EDUS": {
                    "type": "string",
                    "displayName": "EDUS User Transaction"
                  } 
                }
              }
            example: |
              {
                "PO_ProcessMode": "0",
                "DataSelection_EDUS": "JDE"
              }
        responses:
          200:
            description: OK
            body:
              application/json:
                example: !include examples/ube-process.json
#  ===========================================
#  EVENTS
#  ===========================================
#
#  Get Full Customer Information BSFN AddressBookMasterMBF.
#
  /events:
    /getCustomerCreated:
      get:
        description: Get Gustomer using outbound events.
        headers:
          mode:
            displayName: Mode
            description: Execution mode
            type: string
            required: true
            enum: [JDE_PORTX, JDE_ATINA]
        queryParameters:
          qtyRecords:
            displayName: Qty Records to poll (Max. 100)
            type: number
            required: true
        responses:
          200:
            description: OK
            body:
              application/json:
                example: !include examples/events-process.json

 